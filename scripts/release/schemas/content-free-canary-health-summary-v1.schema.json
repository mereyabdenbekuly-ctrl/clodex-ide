{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://clodex.xyz/schemas/release/content-free-canary-health-summary-v1.schema.json",
  "$comment": "Cross-field equality, canonical byte encoding, and freshness are enforced by canary-observation-summaries.mjs.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifactKind",
    "generatedAt",
    "manifest",
    "observation",
    "producer",
    "publication",
    "release",
    "schemaVersion",
    "source"
  ],
  "properties": {
    "artifactKind": {
      "const": "content-free-canary-health-summary-v1"
    },
    "generatedAt": {
      "$ref": "canary-observation-summary-bindings-v1.schema.json#/$defs/instant"
    },
    "manifest": {
      "$ref": "canary-observation-summary-bindings-v1.schema.json#/$defs/manifest"
    },
    "observation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["counters", "endedAt", "startedAt"],
      "properties": {
        "counters": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "authAttempts",
            "authFailures",
            "crashLoops",
            "crashes",
            "dataLossIncidents",
            "egressMissingPrompts",
            "egressPromptAttempts",
            "egressUnexpectedAllows",
            "guardianBypassIncidents",
            "launchAttempts",
            "launchFailures",
            "recoveryAttempts",
            "recoveryFailures"
          ],
          "properties": {
            "authAttempts": { "type": "integer", "minimum": 0 },
            "authFailures": { "type": "integer", "minimum": 0 },
            "crashLoops": { "type": "integer", "minimum": 0 },
            "crashes": { "type": "integer", "minimum": 0 },
            "dataLossIncidents": { "type": "integer", "minimum": 0 },
            "egressMissingPrompts": { "type": "integer", "minimum": 0 },
            "egressPromptAttempts": { "type": "integer", "minimum": 0 },
            "egressUnexpectedAllows": { "type": "integer", "minimum": 0 },
            "guardianBypassIncidents": { "type": "integer", "minimum": 0 },
            "launchAttempts": { "type": "integer", "minimum": 0 },
            "launchFailures": { "type": "integer", "minimum": 0 },
            "recoveryAttempts": { "type": "integer", "minimum": 0 },
            "recoveryFailures": { "type": "integer", "minimum": 0 }
          }
        },
        "endedAt": {
          "$ref": "canary-observation-summary-bindings-v1.schema.json#/$defs/instant"
        },
        "startedAt": {
          "$ref": "canary-observation-summary-bindings-v1.schema.json#/$defs/instant"
        }
      }
    },
    "producer": {
      "$ref": "canary-observation-summary-bindings-v1.schema.json#/$defs/producer"
    },
    "publication": {
      "$ref": "canary-observation-summary-bindings-v1.schema.json#/$defs/publication"
    },
    "release": {
      "$ref": "canary-observation-summary-bindings-v1.schema.json#/$defs/release"
    },
    "schemaVersion": {
      "const": 1
    },
    "source": {
      "$ref": "canary-observation-summary-bindings-v1.schema.json#/$defs/source"
    }
  }
}
