# ===============================
# BUILD Mode configuration
# ===============================
BUILD_MODE=development

# If you want to override the electron binary name, uncomment the following var
# ELECTRON_OVERRIDE_DIST_PATH=/path/to/custom/electron/binary

# ===============================
# Analytics & Telemetry
# ===============================
POSTHOG_API_KEY=...
VITE_POSTHOG_API_KEY=...

# Used for source map uploading during packaging
POSTHOG_CLI_API_KEY=...
POSTHOG_CLI_PROJECT_ID=...
POSTHOG_CLI_HOST=https://us.posthog.com


# ===============================
# Clodex Auth & API
# ===============================
CLODEX_ORIGIN=https://clodex.xyz
CLODEX_LOGIN_URL=https://clodex.xyz/login
CLODEX_API_URL=https://clodex.xyz/api
CLODEX_LLM_RELAY_URL=https://clodex.xyz/v1
CLODEX_AUTH_CALLBACK_SCHEME=clodex-ide
CLODEX_IDE_CLIENT_ID=clodex-ide
CLODEX_AUTH_ENABLED=true

# Emergency isolated-runtime kill switch for canary/nightly builds.
# Equivalent launch flag: --disable-isolated-agent-runtime
CLODEX_DISABLE_ISOLATED_AGENT_RUNTIME=false

# Cloud Tasks dogfood control plane. Release builds remain default-disabled.
# CLODEX_CLOUD_TASKS_URL=https://cloud.example.com
# CLODEX_CLOUD_TASKS_RESIDENCY=us
# Emergency stop for all cloud execution admission.
CLODEX_CLOUD_TASKS_KILL_SWITCH=false

# Local packaging only. Skips macOS signing/notarization for a release-channel
# smoke package. The Forge config rejects this switch in CI.
CLODEX_ALLOW_UNSIGNED_LOCAL_BUILD=false

API_URL=https://clodex.xyz/api

# OAuth callback scheme for the Electron auth handoff is derived from RELEASE_CHANNEL:
# - MVP Clodex flow: clodex-ide://auth/callback
# Clodex login should redirect to:
# https://clodex.xyz/login?redirect=clodex-ide://auth/callback

# Link to the Clodex OpenAI-compatible LLM relay
LLM_PROXY_URL=https://clodex.xyz/v1

# Link to console for account management
CLODEX_CONSOLE_URL=https://clodex.xyz
VITE_CLODEX_CONSOLE_URL=https://clodex.xyz
VITE_CLODEX_ORIGIN=https://clodex.xyz

# Cloudflare Turnstile (invisible CAPTCHA for auth endpoints)
VITE_TURNSTILE_SITE_KEY=...


# URL that the app checks for updates
UPDATE_SERVER_ORIGIN=https://clodex.xyz/api/updates


# ===============================
#  Prod build secrets
# ===============================

# Apple prod build (signing & notarization)
APPLE_ID=...
APPLE_PASSWORD=...
APPLE_TEAM_ID=...

# Windows prod build (Azure Trusted Signing)
AZURE_TENANT_ID=...
AZURE_CLIENT_ID=...
AZURE_CLIENT_SECRET=...
AZURE_ACCOUNT_NAME=...
AZURE_ACCOUNT_ENDPOINT_URI=...
AZURE_CERTIFICATE_PROFILE_NAME=...
