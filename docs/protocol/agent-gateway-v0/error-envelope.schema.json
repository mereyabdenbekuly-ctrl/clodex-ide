{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.clodex.dev/agent-gateway/v0/error-envelope.schema.json",
  "title": "CLODEx Agent Gateway Error Envelope v0",
  "description": "A pre-lifecycle protocol or transport error. This envelope is not authorization evidence or an effect receipt.",
  "type": "object",
  "additionalProperties": false,
  "required": ["kind", "protocolVersion", "correlationId", "error", "issuedAt"],
  "properties": {
    "kind": {
      "const": "clodex.agent-gateway.error"
    },
    "protocolVersion": {
      "$ref": "common.schema.json#/$defs/DraftProtocolVersion"
    },
    "correlationId": {
      "$ref": "common.schema.json#/$defs/OpaqueIdentifier"
    },
    "requestId": {
      "$ref": "common.schema.json#/$defs/OpaqueIdentifier"
    },
    "error": {
      "type": "object",
      "additionalProperties": false,
      "required": ["code", "category", "retryable", "message"],
      "properties": {
        "code": {
          "type": "string",
          "enum": [
            "MALFORMED_ENVELOPE",
            "UNSUPPORTED_VERSION",
            "AUTHENTICATION_FAILED",
            "SIGNATURE_INVALID",
            "REPLAY_DETECTED",
            "IDEMPOTENCY_CONFLICT",
            "BINDING_MISMATCH",
            "EVIDENCE_INVALID",
            "EVIDENCE_REPLAY",
            "POLICY_UNAVAILABLE",
            "GATEWAY_UNAVAILABLE",
            "INTERNAL_ERROR"
          ]
        },
        "category": {
          "type": "string",
          "enum": [
            "PROTOCOL",
            "AUTHENTICATION",
            "REPLAY_PROTECTION",
            "AUTHORIZATION",
            "AVAILABILITY",
            "INTERNAL"
          ]
        },
        "retryable": {
          "type": "boolean"
        },
        "message": {
          "type": "string",
          "minLength": 1,
          "maxLength": 512
        },
        "detailsDigest": {
          "$ref": "common.schema.json#/$defs/Digest"
        },
        "retryAfterSeconds": {
          "type": "integer",
          "minimum": 0,
          "maximum": 86400
        },
        "supportedVersions": {
          "type": "array",
          "minItems": 1,
          "maxItems": 16,
          "uniqueItems": true,
          "items": {
            "$ref": "common.schema.json#/$defs/ProtocolVersion"
          }
        }
      },
      "allOf": [
        {
          "oneOf": [
            {
              "properties": {
                "code": {
                  "enum": ["MALFORMED_ENVELOPE", "UNSUPPORTED_VERSION"]
                },
                "category": {
                  "const": "PROTOCOL"
                },
                "retryable": {
                  "const": false
                }
              }
            },
            {
              "properties": {
                "code": {
                  "enum": ["AUTHENTICATION_FAILED", "SIGNATURE_INVALID"]
                },
                "category": {
                  "const": "AUTHENTICATION"
                },
                "retryable": {
                  "const": false
                }
              }
            },
            {
              "properties": {
                "code": {
                  "enum": [
                    "REPLAY_DETECTED",
                    "IDEMPOTENCY_CONFLICT",
                    "EVIDENCE_REPLAY"
                  ]
                },
                "category": {
                  "const": "REPLAY_PROTECTION"
                },
                "retryable": {
                  "const": false
                }
              }
            },
            {
              "properties": {
                "code": {
                  "enum": ["BINDING_MISMATCH", "EVIDENCE_INVALID"]
                },
                "category": {
                  "const": "AUTHORIZATION"
                },
                "retryable": {
                  "const": false
                }
              }
            },
            {
              "properties": {
                "code": {
                  "enum": ["POLICY_UNAVAILABLE", "GATEWAY_UNAVAILABLE"]
                },
                "category": {
                  "const": "AVAILABILITY"
                },
                "retryable": {
                  "const": true
                }
              }
            },
            {
              "properties": {
                "code": {
                  "const": "INTERNAL_ERROR"
                },
                "category": {
                  "const": "INTERNAL"
                },
                "retryable": {
                  "const": true
                }
              }
            }
          ]
        },
        {
          "if": {
            "properties": {
              "retryable": {
                "const": false
              }
            },
            "required": ["retryable"]
          },
          "then": {
            "not": {
              "required": ["retryAfterSeconds"]
            }
          }
        },
        {
          "if": {
            "properties": {
              "code": {
                "const": "UNSUPPORTED_VERSION"
              }
            },
            "required": ["code"]
          },
          "then": {
            "required": ["supportedVersions"]
          },
          "else": {
            "not": {
              "required": ["supportedVersions"]
            }
          }
        }
      ]
    },
    "issuedAt": {
      "type": "string",
      "format": "date-time"
    },
    "signature": {
      "$ref": "common.schema.json#/$defs/Signature"
    }
  }
}
