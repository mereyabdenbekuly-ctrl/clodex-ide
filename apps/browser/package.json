{
  "name": "clodex",
  "version": "1.16.0",
  "description": "Clodex Agentic IDE for developers.",
  "keywords": [],
  "license": "AGPL-3.0-only",
  "author": {
    "name": "Clodex contributors",
    "email": "support@clodex.xyz"
  },
  "type": "module",
  "main": ".vite/build/main.js",
  "scripts": {
    "bundle:remote-control-client": "tsx scripts/bundle-remote-control-client.ts",
    "bundle:eslint": "tsx scripts/bundle-eslint-server.ts",
    "check:bundled": "tsx scripts/check-bundled-assets.ts",
    "check:packaging-runtime": "node scripts/check-packaging-runtime.mjs",
    "prepare:bundled": "pnpm bundle:remote-control-client && pnpm check:bundled && pnpm bundle:eslint && pnpm check:bundled",
    "make": "pnpm check:packaging-runtime && pnpm prepare:bundled && cross-env NODE_OPTIONS=--max-old-space-size=8192 dotenv -e ../../.env.prod -- electron-forge make",
    "package": "pnpm check:packaging-runtime && pnpm prepare:bundled && cross-env NODE_OPTIONS=--max-old-space-size=8192 dotenv -e ../../.env -- electron-forge package",
    "package:local": "cross-env RELEASE_CHANNEL=release CLODEX_ALLOW_UNSIGNED_LOCAL_BUILD=true pnpm run package",
    "publish": "pnpm check:packaging-runtime && pnpm prepare:bundled && dotenv -e ../../.env -- electron-forge publish",
    "release:notarize:dmg": "node scripts/notarize-macos-dmg.mjs",
    "release:attribution:check": "node scripts/release-attribution.mjs check",
    "release:attribution:prepare": "node scripts/release-attribution.mjs prepare",
    "release:attribution:test": "node --test scripts/release-attribution.test.mjs",
    "release:validate:artifacts": "node scripts/validate-release-artifacts.mjs",
    "release:validate:macos": "node scripts/validate-macos-release.mjs",
    "release:smoke:linux-installer": "bash scripts/smoke-linux-installer.sh",
    "start": "concurrently -n typecheck,app -c yellow,green \"pnpm typecheck\" \"dotenv -e ../../.env.dev -- electron-forge start\"",
    "start:fast": "dotenv -e ../../.env.dev -- electron-forge start",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "visual:build": "storybook build --output-dir storybook-static",
    "visual:test": "playwright test --config playwright.visual.config.ts",
    "visual:test:update": "playwright test --config playwright.visual.config.ts --update-snapshots",
    "visual:report": "playwright show-report playwright-report",
    "clean-data": "tsx scripts/clean-data.ts",
    "clear-vite-cache": "tsx scripts/clear-vite-cache.ts",
    "build:agent-host": "vite build --config vite.agent-host.config.ts",
    "build:mcp-host": "vite build --config vite.mcp-host.config.ts",
    "smoke:mcp-host": "pnpm -F @clodex/mcp-runtime build && pnpm build:mcp-host && vite build --config vite.mcp-host-smoke.config.ts && electron dist/mcp-host-smoke.mjs",
    "acceptance:mcp-packaged": "tsx --tsconfig tsconfig.backend.json scripts/mcp-packaged-acceptance.ts",
    "sign:publisher-attestation": "tsx scripts/sign-plugin-publisher-attestation.ts",
    "policy:publication": "tsx --tsconfig tsconfig.backend.json scripts/model-fabric-policy-publication.ts",
    "collect:isolated-agent-runtime-evidence": "tsx scripts/collect-isolated-agent-runtime-evidence.ts",
    "check:isolated-agent-runtime-observation-build": "tsx scripts/check-isolated-agent-runtime-observation-build.ts",
    "check:isolated-agent-runtime-promotion": "tsx scripts/check-isolated-agent-runtime-promotion.ts",
    "eval:agentic-app-runtime": "tsx --tsconfig tsconfig.backend.json scripts/run-agentic-app-runtime-evaluation.ts",
    "eval:evidence-memory-quality": "tsx --tsconfig tsconfig.backend.json scripts/run-evidence-memory-quality-evaluation.ts",
    "eval:evidence-memory-trace-replay": "tsx --tsconfig tsconfig.backend.json scripts/run-evidence-memory-trace-replay.ts",
    "dogfood:evidence-memory-live": "dotenv -e ../../.env.dev -- electron scripts/evidence-memory-live-dogfood-bootstrap.cjs",
    "check:evidence-memory-promotion": "pnpm eval:evidence-memory-quality -- --no-write && pnpm eval:evidence-memory-trace-replay -- --no-write",
    "collect:evidence-memory-promotion": "tsx --tsconfig tsconfig.backend.json scripts/collect-evidence-memory-promotion-evidence.ts",
    "check:evidence-memory-rollout": "tsx --tsconfig tsconfig.backend.json scripts/check-evidence-memory-rollout.ts",
    "check:agentic-app-runtime-evaluation": "tsx --tsconfig tsconfig.backend.json scripts/check-agentic-app-runtime-evaluation.ts",
    "collect:agentic-app-runtime-promotion-evidence": "tsx --tsconfig tsconfig.backend.json scripts/collect-agentic-app-runtime-promotion-evidence.ts",
    "check:agentic-app-runtime-promotion": "tsx --tsconfig tsconfig.backend.json scripts/check-agentic-app-runtime-promotion.ts",
    "check:agentic-app-runtime-observation-build": "tsx --tsconfig tsconfig.backend.json scripts/check-agentic-app-runtime-observation-build.ts",
    "check:main-plan-readiness": "tsx --tsconfig tsconfig.backend.json scripts/check-main-plan-readiness.ts",
    "collect:cloud-task-release-evidence": "tsx --tsconfig tsconfig.backend.json scripts/collect-cloud-task-release-evidence.ts",
    "typecheck:agent-host-smoke": "pnpm -F @clodex/agent-core build && tsc -p tsconfig.agent-host-smoke.json --noEmit",
    "smoke:agent-host": "pnpm typecheck:agent-host-smoke && pnpm build:agent-host && vite build --config vite.agent-host-smoke.config.ts && electron scripts/agent-host-smoke-app",
    "smoke:dictation-capabilities": "electron scripts/dictation-hardware-smoke.mjs --mode=capabilities",
    "smoke:dictation-hardware": "electron scripts/dictation-hardware-smoke.mjs",
    "smoke:remote-control-physical": "tsx scripts/remote-control-physical-smoke.ts",
    "smoke:browser-egress:packaged": "tsx --tsconfig tsconfig.backend.json scripts/browser-egress-packaged-acceptance.ts",
    "smoke:cloud-tasks:suspend-resume": "tsx scripts/cloud-task-suspend-resume-smoke.ts",
    "smoke:session-recovery": "tsx scripts/session-recovery-acceptance.ts",
    "smoke:agent-host:fault": "pnpm typecheck:agent-host-smoke && pnpm build:agent-host && vite build --config vite.agent-host-fault-smoke.config.ts && electron scripts/agent-host-fault-smoke-app",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "pnpm -F @clodex/agent-core build && pnpm -F @clodex/agent-shell build && concurrently -n ui,pages,backend,preload,storybook,visual -c blue,red,green,yellow,magenta,cyan \"tsc -p tsconfig.ui.json --noEmit\" \"tsc -p tsconfig.pages.json --noEmit\" \"tsc -p tsconfig.backend.json --noEmit\" \"tsc -p tsconfig.web-content-preload.json --noEmit\" \"tsc -p tsconfig.storybook.json --noEmit\" \"tsc -p tsconfig.visual.json --noEmit\""
  },
