PORT=3000
NODE_ENV=development

APP_NAME=clodex
APP_GITHUB_ORG=clodex
APP_GITHUB_REPO=clodex
GITHUB_TOKEN=

# Required in production. Used for absolute Squirrel.Windows package URLs.
PUBLIC_URL=https://updates.clodex.xyz

# Emergency rollout controls. Changes take effect after the server restarts.
# Prevent bad versions from being selected for updates or fresh downloads.
UPDATE_BLOCKED_VERSIONS=

# Hold channels on known-good releases, for example:
# release=1.16.0,beta=1.17.0-beta003
UPDATE_CHANNEL_PINS=
