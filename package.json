{
  "name": "@clodex/workspace",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "build:apps": "turbo run build --filter='./apps/*'",
    "build:packages": "turbo run build --filter='./packages/*'",
    "build:toolbar": "turbo run build --filter='./toolbar/*'",
    "build:plugins": "turbo run build --filter='./plugins/*'",
    "brand:generate": "node scripts/generate-brand-assets.cjs",
    "clean": "git clean -xdf node_modules",
    "clean:workspaces": "turbo clean",
    "clean:browser-data": "pnpm -F clodex clean-data",
    "dev": "turbo watch dev --concurrency 20",
    "dev:playgrounds": "turbo watch dev --filter='./playgrounds/*' --concurrency 20",
    "dev:examples": "turbo watch dev --filter='./examples/*' --concurrency 20",
    "dev:toolbar": "turbo watch dev --filter='./toolbar/*' --concurrency 20",
    "dev:plugins": "turbo watch dev --filter='./plugins/*' --concurrency 20",
    "check": "biome check .",
    "check:boundaries": "node scripts/ci/check-clodex-boundaries.mjs",
    "check:fix": "biome check . --write",
    "check:governance": "pnpm test:boundaries && pnpm check:boundaries && pnpm check:provenance",
    "check:provenance": "node scripts/ci/check-provenance.mjs",
    "sherif": "pnpm dlx sherif --fix",
    "typecheck": "turbo run typecheck",
    "typecheck:scripts": "tsc --project scripts/release/tsconfig.json --noEmit",
    "test": "turbo run test",
    "test:boundaries": "node --test scripts/ci/check-clodex-boundaries.test.mjs scripts/ci/check-pnpm-bootstrap.test.mjs",
    "copy-readme": "ts-node --esm scripts/copy-readme.ts",
    "version:clodex": "tsx scripts/release/index.ts --package clodex",
    "version:clodex:alpha": "tsx scripts/release/index.ts --package clodex --channel alpha",
    "version:clodex:beta": "tsx scripts/release/index.ts --package clodex --channel beta",
    "version:clodex:release": "tsx scripts/release/index.ts --package clodex --channel release",
    "release:validate:macos": "pnpm --dir apps/browser release:validate:macos",
    "release:attribution:check": "pnpm --dir apps/browser release:attribution:check",
    "release:attribution:test": "pnpm --dir apps/browser release:attribution:test",
    "release:signing:readiness": "node scripts/release/signing-readiness.mjs",
    "release:signing:readiness:test": "node --test scripts/release/signing-readiness.test.mjs scripts/release/release-plumbing.test.mjs",
    "release:preview:validate": "node scripts/release/validate-technical-preview-plan.mjs --manifest=.release-notes/clodex-technical-preview.json",
    "version:karton": "tsx scripts/release/index.ts --package karton",
    "extract:compression-test-data": "tsx scripts/experiments/extract-compression-test-data.ts",
    "security:secrets": "scripts/security/scan-secrets.sh working-tree",
    "security:secrets:history": "scripts/security/scan-secrets.sh history",
    "postinstall": "node -e \"const{chmodSync,existsSync}=require('fs');const p='node_modules/node-pty/prebuilds/'+process.platform+'-'+process.arch+'/spawn-helper';try{if(existsSync(p)){chmodSync(p,0o755);console.log('node-pty: fixed spawn-helper permissions')}}catch(e){console.warn('node-pty: spawn-helper chmod failed:',e.message)}\""
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.15",
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@commitlint/config-pnpm-scopes": "^20.1.0",
    "@clodex/typescript-config": "workspace:*",
    "@types/node": "22.15.2",
    "@types/semver": "^7.7.1",
    "conventional-changelog-cli": "^5.0.0",
    "conventional-changelog-conventionalcommits": "^9.3.1",
    "conventional-recommended-bump": "^11.2.0",
    "git-raw-commits": "^5.0.1",
    "lefthook": "^1.12.2",
    "semver": "^7.8.0",
    "ts-node": "10.9.2",
    "turbo": "2.9.14",
    "typescript": "^5.8.3",
    "yaml": "^2.8.3"
  },
  "packageManager": "pnpm@10.30.3",
  "engines": {
    "node": ">=22.12.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@libsql/darwin-arm64",
      "@libsql/darwin-x64",
      "@libsql/linux-arm64-gnu",
      "@libsql/linux-arm64-musl",
      "@libsql/linux-x64-gnu",
      "@libsql/linux-x64-musl",
      "@libsql/win32-x64-msvc",
      "@parcel/watcher",
      "@posthog/cli",
      "@swc/core",
      "bufferutil",
      "core-js",
      "core-js-pure",
      "electron",
      "electron-winstaller",
      "esbuild",
      "fs-xattr",
      "lefthook",
      "libsql",
      "macos-alias",
      "node-pty",
      "sharp",
      "utf-8-validate"
    ],
    "overrides": {
      "lucide-react": "0.554.0",
      "@types/react": "19.2.14",
      "@types/react-dom": "19.2.3",
      "@types/glob": "8.1.0",
      "@types/minimatch": "5.1.2",
      "@babel/core@>=7.0.0 <7.29.6": "7.29.6",
      "@better-auth/electron@1.6.13>@better-auth/core": "1.6.13",
      "@conventional-changelog/git-client@1.0.1": "2.0.0",
      "@esbuild-kit/core-utils@3.3.2>esbuild": "0.25.9",
      "@opentelemetry/core@2.2.0": "2.8.0",
      "@tootallnate/once@2.0.0": "2.0.1",
      "@xmldom/xmldom@0.8.11": "0.8.13",
      "ajv@>=8.0.0 <8.18.0": "8.18.0",
      "axios@>=1.0.0 <1.16.0": "1.16.0",
      "defu@>=6.0.0 <=6.1.4": "6.1.5",
      "dompurify@>=3.0.0 <3.4.11": "3.4.11",
      "diff@4.0.2": "4.0.4",
      "fast-uri@>=3.0.0 <=3.1.1": "3.1.2",
      "form-data@4.0.5": "4.0.6",
      "handlebars@4.7.8": "4.7.9",
      "js-yaml@>=3.0.0 <3.15.0": "3.15.0",
      "js-yaml@4.1.1": "4.2.0",
      "linkify-it@5.0.0": "5.0.1",
      "lodash@4.17.21": "4.18.0",
      "lodash-es@4.17.22": "4.18.0",
      "markdown-it@>=14.0.0 <14.2.0": "14.2.0",
      "seti-icons@0.0.4>svgo": "-",
      "picomatch@2.3.1": "2.3.2",
      "picomatch@>=4.0.0 <4.0.4": "4.0.4",
      "postcss@>=8.0.0 <8.5.10": "8.5.14",
      "protobufjs@>=7.0.0 <7.6.3": "7.6.3",
      "rollup@>=4.0.0 <4.59.0": "4.59.0",
      "serialize-javascript@6.0.2": "7.0.5",
      "shell-quote@1.8.3": "1.8.4",
      "tar@6.2.1": "7.5.16",
      "tmp@0.0.33": "0.2.7",
      "tmp@0.2.5": "0.2.7",
      "undici@>=7.23.0 <7.28.0": "7.28.0",
      "uuid@10.0.0": "11.1.1",
      "uuid@11.1.0": "11.1.1",
      "vite@>=7.0.0 <7.3.5": "7.3.5",
      "yaml@>=2.0.0 <2.8.3": "2.9.0",
      "ws@>=8.0.0 <8.21.0": "8.21.1"
    }
  },
  "dependencies": {
    "@ai-sdk/amazon-bedrock": "^4.0.77",
    "@ai-sdk/azure": "^3.0.42",
    "@ai-sdk/google-vertex": "^4.0.80",
    "@ai-sdk/openai-compatible": "^2.0.35",
    "@aws-sdk/credential-providers": "^3.1045.0",
    "@better-auth/electron": "1.6.13",
    "@smithy/shared-ini-file-loader": "4.5.6",
    "@streamdown/math": "^1.0.2",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-webgl": "^0.19.0",
    "@xterm/headless": "^6.0.0",
    "@xterm/xterm": "^6.0.0",
    "better-auth": "1.6.23",
    "gray-matter": "^4.0.3",
    "node-pty": "^1.1.0",
    "tsx": "^4.20.3"
  },
  "config": {
    "forge": "./forge.config.mts"
  }
}
