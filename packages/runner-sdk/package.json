{
  "name": "@clodex/runner-sdk",
  "version": "0.1.0",
  "description": "Provider-neutral SDK for registering secure Clodex workspace runners.",
  "license": "MIT",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
